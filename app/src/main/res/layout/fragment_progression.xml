<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="100dp">

        <!-- ══════════ HEADER ══════════ -->
        <TextView
            android:id="@+id/tv_prog_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="36dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="sans-serif-black"
            android:text="Progression"
            android:textColor="#0A0A0A"
            android:textSize="40sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_prog_subtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="24dp"
            android:fontFamily="sans-serif-medium"
            android:text="Your journey so far"
            android:textColor="#5F6369"
            android:textSize="15sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_prog_title" />

        <!-- Loading spinner (hidden once data arrives) -->
        <ProgressBar
            android:id="@+id/pb_prog_loading"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="60dp"
            android:indeterminateTint="#0A0A0A"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_prog_subtitle" />

        <!-- ══════════ CARD 1 — HERO STATS ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_hero"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_prog_subtitle">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <!-- Big number -->
                <TextView
                    android:id="@+id/tv_total_tricks"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="0"
                    android:textColor="#0A0A0A"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_tricks_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="tricks\nlogged"
                    android:textColor="#9E9E9E"
                    android:textSize="14sp"
                    app:layout_constraintBottom_toBottomOf="@id/tv_total_tricks"
                    app:layout_constraintStart_toEndOf="@id/tv_total_tricks"
                    app:layout_constraintTop_toTopOf="@id/tv_total_tricks" />

                <!-- Right side week / month -->
                <TextView
                    android:id="@+id/tv_this_week"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="+0 this week"
                    android:textColor="#3B82F6"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_total_tricks" />

                <TextView
                    android:id="@+id/tv_this_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="+0 this month"
                    android:textColor="#9E9E9E"
                    android:textSize="13sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_this_week" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ CARD 2 — YOUR STYLE ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_style"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_hero">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <!-- Colored top bar -->
                <View
                    android:id="@+id/view_fav_accent"
                    android:layout_width="0dp"
                    android:layout_height="6dp"
                    android:background="#3B82F6"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    app:layout_constraintTop_toBottomOf="@id/view_fav_accent">

                    <TextView
                        android:id="@+id/tv_style_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:letterSpacing="0.12"
                        android:text="YOUR STYLE"
                        android:textColor="#9E9E9E"
                        android:textSize="11sp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tv_fav_category"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:fontFamily="sans-serif-black"
                        android:text="—"
                        android:textColor="#0A0A0A"
                        android:textSize="36sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_style_label" />

                    <TextView
                        android:id="@+id/tv_fav_cat_desc"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="sans-serif-medium"
                        android:text="0 tricks · 0% of your sessions"
                        android:textColor="#9E9E9E"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tv_fav_category" />

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ CARD 3 — BREAKDOWN ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_breakdown"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_style">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_breakdown_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12"
                    android:text="BREAKDOWN"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Row: Flatground -->
                <TextView
                    android:id="@+id/tv_flat_label"
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Flatground"
                    android:textColor="#0A0A0A"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_breakdown_label" />

                <ProgressBar
                    android:id="@+id/pb_flatground"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="10"
                    android:progress="0"
                    android:progressTint="#3B82F6"
                    android:progressBackgroundTint="#F0F0F0"
                    app:layout_constraintBottom_toBottomOf="@id/tv_flat_label"
                    app:layout_constraintEnd_toStartOf="@id/tv_flat_count"
                    app:layout_constraintStart_toEndOf="@id/tv_flat_label"
                    app:layout_constraintTop_toTopOf="@id/tv_flat_label" />

                <TextView
                    android:id="@+id/tv_flat_count"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="end"
                    android:text="0×"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_flat_label" />

                <!-- Row: Pool -->
                <TextView
                    android:id="@+id/tv_pool_label"
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Pool"
                    android:textColor="#0A0A0A"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_flat_label" />

                <ProgressBar
                    android:id="@+id/pb_pool"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="10"
                    android:progress="0"
                    android:progressTint="#8B5CF6"
                    android:progressBackgroundTint="#F0F0F0"
                    app:layout_constraintBottom_toBottomOf="@id/tv_pool_label"
                    app:layout_constraintEnd_toStartOf="@id/tv_pool_count"
                    app:layout_constraintStart_toEndOf="@id/tv_pool_label"
                    app:layout_constraintTop_toTopOf="@id/tv_pool_label" />

                <TextView
                    android:id="@+id/tv_pool_count"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="end"
                    android:text="0×"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_pool_label" />

                <!-- Row: Park -->
                <TextView
                    android:id="@+id/tv_park_label"
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Park"
                    android:textColor="#0A0A0A"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_pool_label" />

                <ProgressBar
                    android:id="@+id/pb_park"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="10"
                    android:progress="0"
                    android:progressTint="#10B981"
                    android:progressBackgroundTint="#F0F0F0"
                    app:layout_constraintBottom_toBottomOf="@id/tv_park_label"
                    app:layout_constraintEnd_toStartOf="@id/tv_park_count"
                    app:layout_constraintStart_toEndOf="@id/tv_park_label"
                    app:layout_constraintTop_toTopOf="@id/tv_park_label" />

                <TextView
                    android:id="@+id/tv_park_count"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="end"
                    android:text="0×"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_park_label" />

                <!-- Row: Street -->
                <TextView
                    android:id="@+id/tv_street_label"
                    android:layout_width="88dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Street"
                    android:textColor="#0A0A0A"
                    android:textSize="13sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_park_label" />

                <ProgressBar
                    android:id="@+id/pb_street"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="0dp"
                    android:layout_height="8dp"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"
                    android:max="10"
                    android:progress="0"
                    android:progressTint="#EF4444"
                    android:progressBackgroundTint="#F0F0F0"
                    app:layout_constraintBottom_toBottomOf="@id/tv_street_label"
                    app:layout_constraintEnd_toStartOf="@id/tv_street_count"
                    app:layout_constraintStart_toEndOf="@id/tv_street_label"
                    app:layout_constraintTop_toTopOf="@id/tv_street_label" />

                <TextView
                    android:id="@+id/tv_street_count"
                    android:layout_width="32dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="end"
                    android:text="0×"
                    android:textColor="#9E9E9E"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/tv_street_label" />

                <!-- Bottom padding spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="4dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_street_label" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ CARD 4 — TRICK STATS ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_trick_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_breakdown">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_tricks_section"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12"
                    android:text="TRICKS"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Most thrown -->
                <TextView
                    android:id="@+id/tv_most_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Most thrown"
                    android:textColor="#5F6369"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_tricks_section" />

                <TextView
                    android:id="@+id/tv_most_thrown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="—"
                    android:textColor="#0A0A0A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_tricks_section" />

                <!-- Divider -->
                <View
                    android:id="@+id/div_tricks_1"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_most_label" />

                <!-- Hardest landed -->
                <TextView
                    android:id="@+id/tv_hardest_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Hardest landed"
                    android:textColor="#5F6369"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/div_tricks_1" />

                <TextView
                    android:id="@+id/tv_hardest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="—"
                    android:textColor="#0A0A0A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/div_tricks_1" />

                <!-- Divider -->
                <View
                    android:id="@+id/div_tricks_2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_hardest_label" />

                <!-- Avg difficulty -->
                <TextView
                    android:id="@+id/tv_avg_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Avg difficulty"
                    android:textColor="#5F6369"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/div_tricks_2" />

                <TextView
                    android:id="@+id/tv_avg_diff"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="—"
                    android:textColor="#F59E0B"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/div_tricks_2" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ CARD 5 — SESSION STATS ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_sessions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_trick_stats">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp">

                <TextView
                    android:id="@+id/tv_sessions_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.12"
                    android:text="SESSIONS"
                    android:textColor="#9E9E9E"
                    android:textSize="11sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- Current streak -->
                <TextView
                    android:id="@+id/tv_streak_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Current streak 🔥"
                    android:textColor="#5F6369"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_sessions_label" />

                <TextView
                    android:id="@+id/tv_streak"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="0 days"
                    android:textColor="#0A0A0A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_sessions_label" />

                <View
                    android:id="@+id/div_sess_1"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_streak_label" />

                <!-- Best session -->
                <TextView
                    android:id="@+id/tv_best_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="Best session"
                    android:textColor="#5F6369"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/div_sess_1" />

                <TextView
                    android:id="@+id/tv_best_session"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="—"
                    android:textColor="#0A0A0A"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/div_sess_1" />

                <View
                    android:id="@+id/div_sess_2"
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:background="#F0F0F0"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_best_label" />

                <!-- Video clips -->
                <TextView
                    android:id="@+id/tv_video_label"
                    android:layout_width="0dp"
