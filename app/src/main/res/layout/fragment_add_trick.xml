<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9F9F9">

    <!-- Step indicator dots -->
    <LinearLayout
        android:id="@+id/ll_step_dots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Navigation buttons at bottom -->
    <LinearLayout
        android:id="@+id/ll_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="32dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btn_back"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#F0F0F0"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:text="Back"
            android:textColor="#0A0A0A"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btn_next"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#111111"
            android:fontFamily="sans-serif-medium"
            android:stateListAnimator="@null"
            android:text="Continue"
            android:textColor="#FFFFFF"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- STEP 0: Measurement                                                     -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/step_measurement"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/ll_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_step_dots">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tv_meas_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="How big?"
                android:textColor="#0A0A0A"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_meas_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#5F6369"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_measurement_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:fontFamily="sans-serif-medium"
                android:textColor="#0A0A0A"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_measurement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/rounded_shadow"
                android:fontFamily="sans-serif-medium"
                android:hint="Enter number"
                android:inputType="number"
                android:padding="16dp"
                android:textColor="#1F1F1F"
                android:textColorHint="#9E9E9E"
                android:textSize="18sp"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_pick_measurement"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:backgroundTint="#F0F0F0"
                android:fontFamily="sans-serif-medium"
                android:stateListAnimator="@null"
                android:text="Select…"
                android:textColor="#0A0A0A"
                android:textSize="15sp"
                android:visibility="gone" />

        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- STEP 1: Trick name                                                       -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/step_name"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/ll_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_step_dots">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Name it"
                android:textColor="#0A0A0A"
                android:textSize="40sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Give this trick a nickname"
                android:textColor="#5F6369"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/et_trick_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:background="@drawable/rounded_shadow"
                android:fontFamily="sans-serif-medium"
                android:hint="e.g., First Kickflip"
                android:inputType="textCapSentences"
                android:maxLines="2"
                android:padding="16dp"
                android:textColor="#1F1F1F"
                android:textColorHint="#9E9E9E"
                android:textSize="16sp" />

        </LinearLayout>
    </FrameLayout>

    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <!-- STEP 2: Video                                                            -->
    <!-- ═══════════════════════════════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/step_video"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/ll_nav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_step_dots">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:text="Any footage?"
                android:textColor="#0A0A0A"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Add a clip (optional)"
                android:textColor="#5F6369"
                android:textSize="15sp" />

            <Button
                android:id="@+id/btn_select_video"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:backgroundTint="#F0F0F0"
                android:fontFamily="sans-serif-medium"
                android:padding="16dp"
                android:stateListAnimator="@null"
                android:text="Select Video"
                android:textColor="#0A0A0A"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tv_video_path"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="No video selected"
                android:textColor="#9E9E9E"
                android:textSize="12sp" />

        </LinearLayout>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
