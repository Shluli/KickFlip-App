<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F4F0">

    <!-- Full-screen fragment container -->
    <FrameLayout
        android:id="@+id/homeFragmentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Profile button — top right -->
    <TextView
        android:id="@+id/btn_profile_avatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:clickable="true"
        android:elevation="2dp"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:gravity="center"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#111111"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ══ BOTTOM NAV BAR — flat, full width, thin top border ══ -->
    <LinearLayout
        android:id="@+id/bottom_nav_bar"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Hairline top border -->
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#E8E8E5"
            android:layout_gravity="top"
            android:visibility="visible"
            android:layout_weight="0"/>

        <!-- WEATHER tab -->
        <LinearLayout
            android:id="@+id/btn_nav_weather"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/ic_weather"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_weather"
                android:tint="#AAAAAA" />

            <TextView
                android:id="@+id/label_weather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Weather"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:letterSpacing="0.03" />

        </LinearLayout>

        <!-- VAULT tab (centre) -->
        <LinearLayout
            android:id="@+id/btn_nav_vault"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <!-- Active pill indicator (set visible via code when selected) -->
            <View
                android:id="@+id/vault_pill"
                android:layout_width="32dp"
                android:layout_height="3dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="-3dp"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/ic_vault"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_vault"
                android:tint="#111111" />

            <TextView
                android:id="@+id/label_vault"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Vault"
                android:textColor="#111111"
                android:textSize="10sp"
                android:letterSpacing="0.03" />

        </LinearLayout>

        <!-- PROGRESSION tab -->
        <LinearLayout
            android:id="@+id/btn_nav_progression"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:id="@+id/ic_progression"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_progression"
                android:tint="#AAAAAA" />

            <TextView
                android:id="@+id/label_progression"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="sans-serif-medium"
                android:text="Progress"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:letterSpacing="0.03" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>