<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <!-- ── GUIDELINE: board / panel split ── -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_split"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.53" />

    <!-- ── BOARD VIEW ── -->
    <uri.app.kickflip.BoardView
        android:id="@+id/board_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/guideline_split"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ── BACK BUTTON ── -->
    <TextView
        android:id="@+id/btn_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_margin="16dp"
        android:background="@drawable/circle_shape"
        android:backgroundTint="#55FFFFFF"
        android:gravity="center"
        android:text="✕"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── SAVE BUTTON ── -->
    <Button
        android:id="@+id/btn_save"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_margin="16dp"
        android:backgroundTint="#3B82F6"
        android:fontFamily="sans-serif-medium"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:stateListAnimator="@null"
        android:text="Save"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── TOOL PANEL (white, rounded top) ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/panel_root"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/rounded_top_white"
        app:layout_constraintTop_toBottomOf="@id/guideline_split"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- TAB BAR -->
        <TextView
            android:id="@+id/tab_shape"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Shape"
            android:textColor="#0A0A0A"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/tab_colors"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tab_colors"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Colors"
            android:textColor="#9E9E9E"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/tab_stickers"
            app:layout_constraintStart_toEndOf="@id/tab_shape"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tab_stickers"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Stickers"
            android:textColor="#9E9E9E"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/tab_draw"
            app:layout_constraintStart_toEndOf="@id/tab_colors"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tab_draw"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center"
            android:text="Draw"
            android:textColor="#9E9E9E"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tab_stickers"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Tab indicator bar -->
        <View
            android:id="@+id/tab_indicator"
            android:layout_width="0dp"
            android:layout_height="3dp"
            android:background="#0A0A0A"
            app:layout_constraintBottom_toBottomOf="@id/tab_shape"
            app:layout_constraintEnd_toEndOf="@id/tab_shape"
            app:layout_constraintStart_toStartOf="@id/tab_shape" />

        <!-- Divider below tabs -->
        <View
            android:id="@+id/tab_divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="#F0F0F0"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_shape" />

        <!-- ════ PANEL: SHAPE ════ -->
        <HorizontalScrollView
            android:id="@+id/panel_shape"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:scrollbars="none"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_divider">

            <LinearLayout
                android:id="@+id/ll_shapes"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

        <!-- ════ PANEL: COLORS ════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/panel_colors"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_divider">

            <!-- Target selectors: Deck / Trucks / Wheels / Grip -->
            <TextView
                android:id="@+id/btn_target_deck"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="#111111"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Deck"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/btn_target_trucks"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_target_trucks"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Trucks"
                android:textColor="#0A0A0A"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/btn_target_wheels"
                app:layout_constraintStart_toEndOf="@id/btn_target_deck"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_target_wheels"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="6dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Wheels"
                android:textColor="#0A0A0A"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/btn_target_grip"
                app:layout_constraintStart_toEndOf="@id/btn_target_trucks"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_target_grip"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="Grip"
                android:textColor="#0A0A0A"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btn_target_wheels"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Grip style row (visible when Grip target selected) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/row_grip_style"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/btn_target_deck">

                <TextView
                    android:id="@+id/btn_grip_none"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:background="#EEEEEE"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="None"
                    android:textColor="#0A0A0A"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/btn_grip_black"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/btn_grip_black"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_marginEnd="6dp"
                    android:background="#111111"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Black"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toStartOf="@id/btn_grip_colored"
                    app:layout_constraintStart_toEndOf="@id/btn_grip_none"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/btn_grip_colored"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:background="#EEEEEE"
                    android:clickable="true"
                    android:focusable="true"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:text="Colored"
                    android:textColor="#0A0A0A"
                    android:textSize="12sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/btn_grip_black"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Color palette -->
            <HorizontalScrollView
                android:id="@+id/color_palette_scroll"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="12dp"
                android:scrollbars="none"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/row_grip_style">

                <LinearLayout
                    android:id="@+id/ll_color_palette"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ════ PANEL: STICKERS ════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/panel_stickers"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_divider">

            <TextView
                android:id="@+id/tv_sticker_hint"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Tap to place · drag to move"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Sticker grid (2 rows) -->
            <GridLayout
                android:id="@+id/grid_stickers"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="4"
                android:rowCount="2"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_sticker_hint" />

            <!-- Size row -->
            <TextView
                android:id="@+id/tv_size_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif-medium"
                android:text="Size"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/grid_stickers" />

            <TextView
                android:id="@+id/btn_size_s"
                android:layout_width="52dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:layout_marginTop="12dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="S"
                android:textColor="#0A0A0A"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/tv_size_label"
                app:layout_constraintTop_toBottomOf="@id/grid_stickers" />

            <TextView
                android:id="@+id/btn_size_m"
                android:layout_width="52dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:layout_marginTop="12dp"
                android:background="#111111"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="M"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/btn_size_s"
                app:layout_constraintTop_toBottomOf="@id/grid_stickers" />

            <TextView
                android:id="@+id/btn_size_l"
                android:layout_width="52dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:layout_marginTop="12dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="L"
                android:textColor="#0A0A0A"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/btn_size_m"
                app:layout_constraintTop_toBottomOf="@id/grid_stickers" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ════ PANEL: DRAW ════ -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/panel_draw"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone"
            android:padding="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tab_divider">

            <!-- Brush size row -->
            <TextView
                android:id="@+id/tv_brush_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="Brush"
                android:textColor="#9E9E9E"
                android:textSize="12sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_brush_s"
                android:layout_width="52dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="S"
                android:textColor="#0A0A0A"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/tv_brush_label"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_brush_m"
                android:layout_width="52dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:background="#111111"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="M"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/btn_brush_s"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_brush_l"
                android:layout_width="52dp"
                android:layout_height="32dp"
                android:layout_marginStart="6dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:text="L"
                android:textColor="#0A0A0A"
                android:textSize="13sp"
                app:layout_constraintStart_toEndOf="@id/btn_brush_m"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_undo"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginStart="16dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="↩ Undo"
                android:textColor="#0A0A0A"
                android:textSize="12sp"
                app:layout_constraintEnd_toStartOf="@id/btn_clear_draw"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/btn_clear_draw"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:background="#EEEEEE"
                android:clickable="true"
                android:focusable="true"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Clear"
                android:textColor="#EF4444"
                android:textSize="12sp"
                android:layout_marginStart="8dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- Draw color palette -->
            <HorizontalScrollView
                android:id="@+id/draw_palette_scroll"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:scrollbars="none"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_brush_label">

                <LinearLayout
                    android:id="@+id/ll_draw_palette"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal" />

            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
